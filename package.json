{
  "name": "sif-generator",
  "version": "1.0.0",
  "description": "SIF Generator - Salary Information File Generator",
  "main": "electron/main.js",
  "author": "SIF Generator",
  "license": "MIT",
  "scripts": {
    "electron": "electron .",
    "build:client": "npm run build --prefix client",
    "package": "npm run build:client && electron-builder --win --x64",
    "package:dir": "npm run build:client && electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.sifgenerator.app",
    "productName": "SIF Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!generated-files/**/*"
        ]
      },
      {
        "from": "client/build",
        "to": "client/build",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SIF Generator"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "mongodb-memory-server": "^10.0.0"
  }
}
